# ===========================================
# ASTRAEUS - Autonomous Life Orchestrator
# Environment Configuration Template
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ===========================================

# -----------------------------
# 🤖 Telegram Bot Configuration
# -----------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Get from @BotFather on Telegram

# Authorized user ID (your Telegram user ID)
TELEGRAM_AUTHORIZED_USER_ID=123456789
# Get your ID by messaging @userinfobot on Telegram

# -----------------------------
# 🧠 AI/LLM Configuration
# -----------------------------
# Choose your AI provider: openai, gemini, or ollama
AI_PROVIDER=gemini

# OpenAI API Key (if using OpenAI)
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# Google Gemini API Key (if using Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# Ollama Configuration (if using local Ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# -----------------------------
# 🗺️ Location & Maps Configuration
# -----------------------------
# Google Maps API Key (optional - can use free OSM)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Use OpenStreetMap instead of Google Maps (free)
USE_OPENSTREETMAP=true

# Default city for weather and transit
DEFAULT_CITY=Istanbul
DEFAULT_COUNTRY=TR
DEFAULT_TIMEZONE=Europe/Istanbul

# -----------------------------
# 🌤️ Weather Configuration
# -----------------------------
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here
# Get free key from https://openweathermap.org/api

# Weather-based time adjustments (in percentage)
RAIN_TIME_BUFFER=20
SNOW_TIME_BUFFER=30
HEAVY_TRAFFIC_BUFFER=25

# -----------------------------
# 📅 Calendar Configuration
# -----------------------------
# Google Calendar (optional)
GOOGLE_CALENDAR_CREDENTIALS_FILE=credentials.json
GOOGLE_CALENDAR_TOKEN_FILE=token.json

# Outlook/Microsoft Calendar (optional)
OUTLOOK_CLIENT_ID=your_outlook_client_id
OUTLOOK_CLIENT_SECRET=your_outlook_client_secret

# -----------------------------
# 💾 Database Configuration
# -----------------------------
DATABASE_URL=postgresql+asyncpg://astraeus:astraeus_password@localhost:5432/astraeus_db

# For Docker deployment
POSTGRES_USER=astraeus
POSTGRES_PASSWORD=astraeus_password
POSTGRES_DB=astraeus_db

# -----------------------------
# ⚙️ Application Settings
# -----------------------------
# User's name for personalized messages
USER_NAME=Tarık

# Default preparation time (minutes)
DEFAULT_PREP_TIME=5

# How often to check for upcoming events (seconds)
EVENT_CHECK_INTERVAL=60

# Minimum warning time before events (minutes)
MIN_WARNING_TIME=15

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# -----------------------------
# 🚀 Deployment Settings
# -----------------------------
# Set to 'production' for VPS deployment
ENVIRONMENT=development

# API webhook URL (for production Telegram webhook mode)
WEBHOOK_URL=https://your-domain.com/webhook
WEBHOOK_PORT=8443
